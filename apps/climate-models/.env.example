# Address on the Docker host that may accept connections. Leave as loopback when
# an authenticated reverse proxy is used, or set to the host's VPN interface IP.
STREAMLIT_BIND_ADDRESS=127.0.0.1

# Absolute path on the Docker host to the AR6 infilling database.
INFILLING_DATABASE_HOST=/srv/climate-assets/infilling.csv

CLIMATE_ASSESSMENT_REF=v0.1.6
MAX_UPLOAD_MB=50
RUN_TIMEOUT_SECONDS=14400
JOB_RETENTION_HOURS=24

# Optional MAGICC configuration. Do not commit licensed assets to this repository.
# Uncomment the MAGICC volume mounts in compose.yaml as well.
# MAGICC_HOST_DIR=/srv/climate-assets/magicc
# MAGICC_EXECUTABLE_7=/opt/magicc/magicc-v7.5.3/bin/magicc
# MAGICC_PROBABILISTIC_FILE=/opt/magicc/0fd0f62-derived-metrics-id-f023edb-drawnset.json
# MAGICC_WORKER_ROOT_DIR=/data/magicc-workers
# MAGICC_WORKER_NUMBER=2
